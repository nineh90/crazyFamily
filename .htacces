# ---------------------------------------------------------
# CRAZYFAMILY – optimierte .htaccess-Konfiguration (Strato)
# ---------------------------------------------------------

# Aktiviert das Rewrite-Modul (muss immer zuerst stehen)
RewriteEngine On

# 1️⃣ HTTPS erzwingen (Weiterleitung von http → https)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2️⃣ Optional: www entfernen (https://www.crazyfamily.info → https://crazyfamily.info)
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

# 3️⃣ Sitemap von Rewrite-Regeln ausnehmen (damit Google sie direkt lesen kann)
<Files "sitemap.xml">
  RewriteEngine Off
</Files>

# 4️⃣ Richtiger MIME-Type für XML-Dateien (Strato-kompatibel)
<FilesMatch "\.xml$">
  RemoveType .xml
  AddType "application/xml; charset=UTF-8" .xml
  DefaultType application/xml
</FilesMatch>


<IfModule mod_headers.c>
  <FilesMatch "\.xml$">
    ForceType application/xml
    Header set Content-Type "application/xml; charset=UTF-8"
  </FilesMatch>
</IfModule>

# 5️⃣ Browser-Caching für statische Dateien (schnellerer Seitenaufbau)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/xml "access plus 1 month"
</IfModule>

# 6️⃣ GZIP-Kompression (reduziert Ladezeiten)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>

# 7️⃣ Standard-Indexdatei festlegen
DirectoryIndex index.html
