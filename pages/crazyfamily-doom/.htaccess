# CrazyFamily Doom — Server-Einstellungen für Strato (Apache)
# Diese Datei einfach mit hochladen. Sie sorgt dafür, dass die Engine schnell
# und korrekt ausgeliefert wird.

# 1) WebAssembly mit korrektem MIME-Typ ausliefern (sonst startet die Engine
#    langsamer bzw. über einen Umweg). WICHTIGSTE Zeile.
AddType application/wasm .wasm

# 2) Große Dateien komprimiert ausliefern (schnellerer Download).
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/wasm
</IfModule>

# 3) Caching: Engine + Spieldaten lange zwischenspeichern (ändern sich selten),
#    damit Wiederkehrer sofort spielen können. Aktualisierungen der Engine
#    erzwingt game.js automatisch über die Versionsnummer (?v=...).
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType application/wasm "access plus 30 days"
  ExpiresByType application/octet-stream "access plus 30 days"
  # HTML/JS kürzer cachen, damit Änderungen ankommen:
  ExpiresByType text/html "access plus 1 hours"
  ExpiresByType application/javascript "access plus 1 hours"
</IfModule>
